rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a "Creator-Ownership" model designed for the AyosGadget repair platform.
     * PUBLIC COLLECTIONS: Categories, Devices, and RepairGuides are publicly readable AND writable 
     * to support the global auto-caching mechanism from iFixit.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isFieldOwner(fieldName) {
      return isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    function isIncomingFieldOwner(fieldName) {
      return isSignedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /savedGuides/{savedGuideId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /troubleshootingSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /progress/{userProgressId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Repair guides. 
     * Open for public read/write to allow the iFixit auto-ingestion engine to work for all users.
     */
    match /repairGuides/{id} {
      allow read, write: if true;

      match /steps/{stepId} {
        allow read, write: if true;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isIncomingFieldOwner('userId');
        allow update, delete: if isFieldOwner('userId');
      }

      match /ratings/{userId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /forumPosts/{forumPostId} {
      allow read: if true;
      allow create: if isIncomingFieldOwner('userId');
      allow update, delete: if isFieldOwner('userId');

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isIncomingFieldOwner('userId');
        allow update, delete: if isFieldOwner('userId');
      }
    }

    /**
     * @description GLOBAL REFERENCE COLLECTIONS
     * Wide open for reads to ensure protocols are always available.
     * Writable by all to support auto-syncing of master modules.
     */
    match /categories/{id} { allow read, write: if true; }
    match /devices/{id} { allow read, write: if true; }
    match /tools/{id} { allow read, write: if true; }
    match /parts/{id} { allow read, write: if true; }
    match /tags/{id} { allow read, write: if true; }
    match /badges/{id} { allow read, write: if true; }
    match /nearbyRepairShops/{id} { allow read: if true; allow write: if false; }

  }
}