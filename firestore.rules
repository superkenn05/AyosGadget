rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a "Creator-Ownership" model designed for the AyosGadget repair platform.
     * It prioritizes high-speed iteration by allowing flexible data shapes while maintaining 
     * strict authorization boundaries.
     *
     * DATA STRUCTURE
     * 1. Public Content: Categories, Devices, Tools, and Parts are globally readable.
     *    Authenticated users can write to these for caching purposes from iFixit.
     * 2. User-Generated Content: Repair Guides and Forum Posts are publicly readable but writable only 
     *    by their respective authors.
     * 3. Private User Space: Saved items, troubleshooting sessions, and progress are strictly private.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isFieldOwner(fieldName) {
      return isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    function isIncomingFieldOwner(fieldName) {
      return isSignedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /savedGuides/{savedGuideId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /troubleshootingSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /progress/{userProgressId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Repair guides. 
     * Now allows authenticated users to 'create' for caching from iFixit.
     * Updates and deletes still restricted to the original author.
     */
    match /repairGuides/{repairGuideId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isFieldOwner('authorId');
      allow delete: if isFieldOwner('authorId');

      match /steps/{stepId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update: if isFieldOwner('repairGuideAuthorId');
        allow delete: if isFieldOwner('repairGuideAuthorId');
      }

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isIncomingFieldOwner('userId');
        allow update: if isFieldOwner('userId');
        allow delete: if isFieldOwner('userId');
      }

      match /ratings/{userId} {
        allow get, list: if true;
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    match /forumPosts/{forumPostId} {
      allow get, list: if true;
      allow create: if isIncomingFieldOwner('userId');
      allow update: if isFieldOwner('userId');
      allow delete: if isFieldOwner('userId');

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isIncomingFieldOwner('userId');
        allow update: if isFieldOwner('userId');
        allow delete: if isFieldOwner('userId');
      }
    }

    /**
     * @description REFERENCE COLLECTIONS
     * Allowing authenticated users to 'create' or 'update' to support auto-caching from iFixit.
     */
    match /categories/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /devices/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /tools/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /parts/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /tags/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /badges/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /nearbyRepairShops/{id} { allow read: if true; allow write: if false; }

  }
}