
{
  "entities": {
    "Bookmark": {
      "title": "Bookmark",
      "description": "A saved repair guide for a user.",
      "type": "object",
      "properties": {
        "guideId": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "category": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["guideId", "title", "savedAt"]
    },
    "CachedGuide": {
      "title": "Cached Guide",
      "description": "A mirrored copy of an iFixit guide for faster access.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "device": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string" },
        "timeEstimate": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "steps": { "type": "array" },
        "tools": { "type": "array" },
        "cachedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's bookmarked repair guides."
    },
    "/guides/{guideId}": {
      "schema": "CachedGuide",
      "description": "Mirrored repair guides from iFixit."
    }
  }
}
